generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Query {
  id         String        @id @default(cuid())
  text       String
  category   String
  date       String
  poly       String
  viz_hint   String
  created_at DateTime      @default(now())
  results    CrimeResult[]
}

model CrimeResult {
  id               Int      @id @default(autoincrement())
  query_id         String
  query            Query    @relation(fields: [query_id], references: [id])
  persistent_id    String
  category         String
  month            String
  street           String
  latitude         Float
  longitude        Float
  outcome_category String?
  outcome_date     String?
  location_type    String
  context          String?
  created_at       DateTime @default(now())

  @@map("crime_results")
}

model SchemaVersion {
  id           Int      @id @default(autoincrement())
  table_name   String
  column_name  String
  column_type  String
  triggered_by String
  created_at   DateTime @default(now())
}